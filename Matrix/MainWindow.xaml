<Window x:Class="Matrix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор матриць"
        MinHeight="600" MinWidth="800"
        Height="750" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#EFEFEF"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="MatrixGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#CCCCCC"/>
            <Setter Property="VerticalGridLinesBrush" Value="#CCCCCC"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F7F7"/>
            <Setter Property="FontSize" Value="13"/>
            <!-- Трохи зменшений шрифт для кращого вміщення -->
            <Setter Property="ColumnWidth" Value="*"/>
            <Setter Property="MinColumnWidth" Value="45"/>
            <!-- Захист від надмірного стиснення -->
            <Setter Property="RowHeight" Value="28"/>
            <!-- Зменшена висота рядка (було 32) -->
            <Setter Property="HeadersVisibility" Value="None"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="OpButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок + статус -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Калькулятор матриць"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#222222" Margin="0,0,0,2"/>
            <TextBlock x:Name="TxtLoadStatus" FontSize="12"
                       Foreground="#777777" Text=""/>
        </StackPanel>

        <!-- Матриці A і B -->
        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Матриця A -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Матриця A" FontSize="13"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Рядки:" VerticalAlignment="Center" FontSize="12" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtARows" Text="7" Width="38" Height="24" FontSize="12"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 BorderBrush="#BBBBBB"/>
                        <TextBlock Text="Стовп.:" VerticalAlignment="Center" FontSize="12" Margin="10,0,5,0"/>
                        <TextBox x:Name="TxtACols" Text="7" Width="38" Height="24" FontSize="12"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 BorderBrush="#BBBBBB"/>
                        <Button Content="Застосувати" Margin="8,0,0,0" Width="76" Height="24" FontSize="12"
                                Background="#DDDDDD" BorderThickness="0" Cursor="Hand" Click="BtnApplyA_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="GridA" Style="{StaticResource MatrixGrid}"/>
                </Grid>
            </Border>

            <!-- Матриця B -->
            <Border Grid.Column="2" Background="White"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Матриця B" FontSize="13"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Рядки:" VerticalAlignment="Center" FontSize="12" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtBRows" Text="7" Width="38" Height="24" FontSize="12"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 BorderBrush="#BBBBBB"/>
                        <TextBlock Text="Стовп.:" VerticalAlignment="Center" FontSize="12" Margin="10,0,5,0"/>
                        <TextBox x:Name="TxtBCols" Text="7" Width="38" Height="24" FontSize="12"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 BorderBrush="#BBBBBB"/>
                        <Button Content="Застосувати" Margin="8,0,0,0" Width="76" Height="24" FontSize="12"
                                Background="#DDDDDD" BorderThickness="0" Cursor="Hand" Click="BtnApplyB_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="GridB" Style="{StaticResource MatrixGrid}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="A + B" Width="100" Style="{StaticResource OpButton}"
                    Background="#3949AB" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button Content="A − B" Width="100" Style="{StaticResource OpButton}"
                    Background="#7B1FA2" Margin="0,0,8,0" Click="BtnSubtract_Click"/>
            <Button Content="A × B" Width="100" Style="{StaticResource OpButton}"
                    Background="#00796B" Margin="0,0,20,0" Click="BtnMultiply_Click"/>
            <Separator Width="1" Height="30" Margin="0,0,20,0"/>
            <Button Content="Зберегти" Width="110" Style="{StaticResource OpButton}"
                    Background="#546E7A" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Завантажити" Width="130" Style="{StaticResource OpButton}"
                    Background="#546E7A" Click="BtnLoad_Click"/>
        </StackPanel>

        <!-- Помилка -->
        <Border Grid.Row="3" x:Name="ErrorPanel" Background="#FFEBEE"
                BorderBrush="#EF9A9A" BorderThickness="1"
                CornerRadius="4" Padding="10,7" Margin="0,10,0,0" Visibility="Collapsed">
            <TextBlock x:Name="TxtError" FontSize="12"
                       Foreground="#C62828" TextWrapping="Wrap"/>
        </Border>

        <!-- Результат -->
        <Border Grid.Row="4" Background="White" BorderBrush="#CCCCCC"
                BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Результат" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtResultInfo" FontSize="12" Foreground="#888888" 
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="— оберіть операцію вище"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="GridResult"
                          Style="{StaticResource MatrixGrid}"
                          IsReadOnly="True" Background="#F5FFF5"/>
            </Grid>
        </Border>

    </Grid>
</Window>